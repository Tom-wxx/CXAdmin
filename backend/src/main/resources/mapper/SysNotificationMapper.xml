<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.admin.system.mapper.SysNotificationMapper">

    <resultMap id="SysNotificationResult" type="com.admin.system.entity.SysNotification">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="type" column="type"/>
        <result property="priority" column="priority"/>
        <result property="status" column="status"/>
        <result property="userId" column="user_id"/>
        <result property="senderId" column="sender_id"/>
        <result property="senderName" column="sender_name"/>
        <result property="linkUrl" column="link_url"/>
        <result property="linkType" column="link_type"/>
        <result property="readTime" column="read_time"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
        <result property="remark" column="remark"/>
    </resultMap>

    <!-- 获取用户未读消息数量 -->
    <select id="countUnreadByUserId" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM sys_notification
        WHERE user_id = #{userId}
          AND status = 'unread'
          AND deleted = 0
    </select>

    <!-- 批量标记消息为已读 -->
    <update id="batchMarkAsRead">
        UPDATE sys_notification
        SET status = 'read',
            read_time = NOW(),
            update_time = NOW()
        WHERE user_id = #{userId}
          AND id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
          AND deleted = 0
    </update>

    <!-- 全部标记为已读 -->
    <update id="markAllAsRead">
        UPDATE sys_notification
        SET status = 'read',
            read_time = NOW(),
            update_time = NOW()
        WHERE user_id = #{userId}
          AND status = 'unread'
          AND deleted = 0
    </update>

</mapper>
