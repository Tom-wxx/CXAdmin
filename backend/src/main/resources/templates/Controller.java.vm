package ${packageName}.controller;

import ${packageName}.entity.${className};
import ${packageName}.service.I${className}Service;
import com.admin.system.common.PageResult;
import com.admin.system.common.Result;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.*;

/**
 * ${tableComment}Controller
 *
 * @author ${author}
 * @date ${datetime}
 */
@RestController
@RequestMapping("/${moduleName}/${classname}")
public class ${className}Controller {

    @Autowired
    private I${className}Service ${classname}Service;

    /**
     * 查询${tableComment}列表
     */
    @PreAuthorize("@ss.hasPermi('${moduleName}:${classname}:list')")
    @GetMapping("/list")
    public Result<PageResult<${className}>> list(${className} ${classname},
                                                   @RequestParam(defaultValue = "1") Integer current,
                                                   @RequestParam(defaultValue = "10") Integer size) {
        PageResult<${className}> pageResult = ${classname}Service.select${className}List(${classname}, current, size);
        return Result.success(pageResult);
    }

    /**
     * 根据ID查询${tableComment}
     */
    @PreAuthorize("@ss.hasPermi('${moduleName}:${classname}:query')")
    @GetMapping("/{${primaryKey.propertyName}}")
    public Result<${className}> getInfo(@PathVariable ${primaryKey.javaType} ${primaryKey.propertyName}) {
        ${className} ${classname} = ${classname}Service.select${className}ById(${primaryKey.propertyName});
        return Result.success(${classname});
    }

    /**
     * 新增${tableComment}
     */
    @PreAuthorize("@ss.hasPermi('${moduleName}:${classname}:add')")
    @PostMapping
    public Result add(@RequestBody ${className} ${classname}) {
        int result = ${classname}Service.insert${className}(${classname});
        return result > 0 ? Result.success("新增成功") : Result.fail("新增失败");
    }

    /**
     * 修改${tableComment}
     */
    @PreAuthorize("@ss.hasPermi('${moduleName}:${classname}:edit')")
    @PutMapping
    public Result edit(@RequestBody ${className} ${classname}) {
        int result = ${classname}Service.update${className}(${classname});
        return result > 0 ? Result.success("修改成功") : Result.fail("修改失败");
    }

    /**
     * 删除${tableComment}
     */
    @PreAuthorize("@ss.hasPermi('${moduleName}:${classname}:remove')")
    @DeleteMapping("/{${primaryKey.propertyName}s}")
    public Result remove(@PathVariable ${primaryKey.javaType}[] ${primaryKey.propertyName}s) {
        int result = ${classname}Service.delete${className}ByIds(${primaryKey.propertyName}s);
        return result > 0 ? Result.success("删除成功") : Result.fail("删除失败");
    }
}
